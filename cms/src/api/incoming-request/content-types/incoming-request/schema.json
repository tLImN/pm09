{
  "kind": "collectionType",
  "collectionName": "incoming_requests",
  "info": {
    "singularName": "incoming-request",
    "pluralName": "incoming-requests",
    "displayName": "Входящие заявки"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "request_date": {
      "type": "datetime",
      "required": true
    },
    "name": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "message": {
      "type": "text"
    },
    "contact_method": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "phone",
        "email"
      ]
    },
    "request_type": {
      "type": "enumeration",
      "required": true,
      "default": "callback",
      "enum": [
        "callback",
        "quote",
        "service"
      ]
    },
    "items": {
      "type": "json"
    },
    "items_summary": {
      "type": "text"
    },
    "page_url": {
      "type": "string"
    }
  }
}
