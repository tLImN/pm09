# ===========================================
# Strapi CMS Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=1337

# App keys (comma-separated, generate random strings for production)
APP_KEYS=base64key1=,base64key2=,base64key3=,base64key4=

# API Token Salt (generate a random string)
API_TOKEN_SALT=random-api-token-salt

# Admin JWT Secret (generate a random string)
ADMIN_JWT_SECRET=random-admin-jwt-secret

# Transfer Token Salt (generate a random string)
TRANSFER_TOKEN_SALT=random-transfer-token-salt

# JWT Secret (generate a random string)
JWT_SECRET=random-jwt-secret

# Database (PostgreSQL via Docker)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false