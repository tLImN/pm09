# ===========================================
# Next.js Frontend Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in the values

# Strapi API URL (default: localhost for local development)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Внутренний URL Strapi для серверных запросов (Next.js API routes, SSR).
STRAPI_INTERNAL_URL=http://localhost:1337
CONTACT_EMAIL=info@aforklift.ru
# SMTP опционально — если не заданы, форма работает в режиме заглушки
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

NODE_OPTIONS=--max-old-space-size=4096

# Yandex Tiles API
NEXT_PUBLIC_YANDEX_TILES_API_KEY=